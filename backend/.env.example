# DhanHQ API token mode (paste token + client id)
# Access token from Dhan (valid ~24h). Keep this secret and do not commit.
DHANHQ_ACCESS_TOKEN=your_access_token_here
DHANHQ_CLIENT_ID=your_dhan_client_id_here

DHANHQ_BASE_URL=https://api.dhan.co/v2

# Nifty 50 Index only (not ETFs) — Dhan SECURITY_ID 13
NIFTY_SECURITY_ID=13
NIFTY_EXCHANGE_SEGMENT=IDX_I

# Optional: live metrics (from Dhan instrument master)
# NIFTY_FUTURES_SECURITY_ID=
# NIFTY_FUTURES_EXCHANGE_SEGMENT=NSE_FNO
INDIA_VIX_SECURITY_ID=21
INDIA_VIX_EXCHANGE_SEGMENT=IDX_I

# Auto-written after OAuth login (do not edit manually)
# DHANHQ_TOKEN_FILE=backend/.dhan_token.json

# App
ENVIRONMENT=development
DEBUG=true

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated). Include your Netlify URL in production.
CORS_ORIGINS=https://twiqpro.netlify.app,http://localhost:3000,http://127.0.0.1:3000
