# DhanHQ API key + secret (OAuth) — https://dhanhq.co/docs/v2/authentication/#api-key-secret
# Create at web.dhan.co → My Profile → Access DhanHQ APIs → API key tab
DHANHQ_APP_ID=your_api_key_here
DHANHQ_APP_SECRET=your_api_secret_here
DHANHQ_CLIENT_ID=your_dhan_client_id_here

# Must match the Redirect URL registered when creating the API key
DHANHQ_REDIRECT_URL=http://localhost:8000/api/auth/dhan/callback

DHANHQ_BASE_URL=https://api.dhan.co/v2
DHANHQ_AUTH_URL=https://auth.dhan.co

# Nifty 50 Index only (not ETFs) — Dhan SECURITY_ID 13
NIFTY_SECURITY_ID=13
NIFTY_EXCHANGE_SEGMENT=IDX_I

# Auto-written after OAuth login (do not edit manually)
# DHANHQ_TOKEN_FILE=backend/.dhan_token.json

# App
ENVIRONMENT=development
DEBUG=true

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
