{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "twiq-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-28",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "NEXT_PUBLIC_SITE_URL": "https://twiq.pro",
    "NEXT_PUBLIC_SUPABASE_URL": "https://vcpqnstvrggynaqnxtmn.supabase.co",
    "NEXT_PUBLIC_API_URL": "https://twiq-web.onrender.com",
    "NEXT_PUBLIC_WS_URL": "wss://twiq-web.onrender.com"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "twiq-web"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "routes": [
    {
      "pattern": "twiq.pro",
      "custom_domain": true
    },
    {
      "pattern": "www.twiq.pro",
      "custom_domain": true
    }
  ]
}
