# --- Production (Cloudflare) ---
# Public URLs are in frontend/wrangler.jsonc vars.
# Set the anon JWT via: wrangler secret put NEXT_PUBLIC_SUPABASE_ANON_KEY
# Or Cloudflare dashboard → Workers → twiq-web → Settings → Variables (encrypted).
NEXT_PUBLIC_SITE_URL=https://twiq.pro
NEXT_PUBLIC_SUPABASE_URL=https://vcpqnstvrggynaqnxtmn.supabase.co
# Legacy anon public JWT (eyJ...), not sb_publishable_* keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=https://twiq-web.onrender.com
NEXT_PUBLIC_WS_URL=wss://twiq-web.onrender.com

