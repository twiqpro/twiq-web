# --- Production (Cloudflare Workers build env) ---
NEXT_PUBLIC_SITE_URL=https://twiq.pro
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the legacy "anon public" JWT (eyJ...), not sb_publishable_* keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=https://twiq-web.onrender.com
NEXT_PUBLIC_WS_URL=wss://twiq-web.onrender.com

